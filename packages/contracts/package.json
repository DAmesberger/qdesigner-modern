{
  "name": "@qdesigner/contracts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated/*": {
      "types": "./src/generated/*.ts",
      "default": "./src/generated/*.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "openapi-ts --file ./openapi-ts.config.ts"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.94.0",
    "typescript": "~5.8.3"
  }
}

  "query": "\n            SELECT id, session_id, question_id, value, reaction_time_us,\n                   presented_at, answered_at, metadata as \"metadata!\", created_at, client_id\n            FROM responses\n            WHERE session_id = $1 AND question_id = $2\n            ORDER BY created_at ASC\n            LIMIT $3 OFFSET $4\n            ",

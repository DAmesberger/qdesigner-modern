# QDesigner Modern - Environment Configuration
# Copy this file to .env.development for local development

# ---------- Database ----------
# Application connects as the non-superuser non-BYPASSRLS role
# `qdesigner_app` so RLS policies actually bind on application traffic
# (ADR 0014). Migrations run as the bootstrap superuser `qdesigner` via
# DATABASE_URL_MIGRATIONS — leave it unset and migrations run on the app
# pool, which only works if the app role has DDL rights (legacy mode).
DATABASE_URL=postgresql://qdesigner_app:qdesigner_app@localhost:15434/qdesigner
DATABASE_URL_MIGRATIONS=postgresql://qdesigner:qdesigner@localhost:15434/qdesigner

# ---------- Auth ----------
# JWT signing secret (must be at least 32 characters)
JWT_SECRET=change-me-to-a-secure-secret-at-least-32-characters
# Separate secret for refresh tokens
JWT_REFRESH_SECRET=change-me-to-another-secure-secret-at-least-32-chars
# Access token expiry in seconds (default: 15 minutes)
JWT_ACCESS_EXPIRY=900
# Refresh token expiry in seconds (default: 7 days)
JWT_REFRESH_EXPIRY=604800
# Primary auth provider. Use `local` only for local development/tests.
# Production-like environments (`APP_ENV`, `RUST_ENV`, `NODE_ENV`, or
# `ENVIRONMENT` set to prod/production/staging/shared) reject local auth.
AUTH_PROVIDER=local
# Symmetric secret used to encrypt server-side OIDC token material and hash
# pseudonymized auth metadata. Set a dedicated high-entropy value in production.
AUTH_TOKEN_ENC_KEY=change-me-to-a-secure-auth-token-encryption-key
AUTH_IP_HASH_KEY=change-me-to-a-secure-auth-ip-hash-key
# Server-side qdesigner session policy.
AUTH_SESSION_IDLE_SECS=28800
AUTH_SESSION_ABSOLUTE_SECS=604800
AUTH_SESSION_RETENTION_SECS=2592000
SECURITY_EVENT_RETENTION_SECS=31536000
# Zitadel OIDC settings, required when AUTH_PROVIDER=zitadel.
# ZITADEL_ISSUER=https://your-zitadel.example.com
# ZITADEL_CLIENT_ID=
# ZITADEL_CLIENT_SECRET=
# ZITADEL_REDIRECT_URI=https://your-app.example.com/api/auth/zitadel/callback
# ZITADEL_POST_LOGOUT_REDIRECT_URI=https://your-app.example.com/login
# ZITADEL_INCLUDE_PROFILE_SCOPE=false
# ZITADEL_ALLOW_SMS_EMAIL_MFA=false

# ---------- Storage (MinIO) ----------
# MinIO S3-compatible API endpoint
MINIO_ENDPOINT=http://localhost:19003
# MinIO root credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Bucket for media uploads
MINIO_BUCKET=qdesigner-media

# ---------- Redis ----------
# Redis connection URL for caching and sessions
REDIS_URL=redis://localhost:16381

# ---------- Email (MailPit in dev) ----------
# SMTP server host
SMTP_HOST=localhost
# SMTP server port
SMTP_PORT=11026
# Sender address for outgoing emails
SMTP_FROM=noreply@qdesigner.local

# ---------- Server ----------
# Public frontend host/port used for dev links, Vite, and CORS defaults.
APP_HOST=localhost
APP_PORT=4173
# Host and port the Rust backend listens on
SERVER_HOST=0.0.0.0
SERVER_PORT=4100

# ---------- Frontend ----------
# Backend API URL (used by SvelteKit client). Leave blank in local dev to use the Vite proxy.
VITE_API_URL=
# Mirrors AUTH_PROVIDER for UI selection. Set to `zitadel` to show the primary
# Zitadel sign-in action instead of local email/password.
VITE_AUTH_PROVIDER=local
# Optional test-mode auto-login credentials (used by window.testMode.enable())
# VITE_TEST_MODE_EMAIL=
# VITE_TEST_MODE_PASSWORD=

# Dev-only quick-login personas shown on /login (development only)
# Set VITE_DEV_QUICK_LOGIN_ENABLED=true to display persona buttons.
# Set DEV_HELPERS_ENABLED=true to allow /api/dev/bootstrap-personas
# in non-debug builds.
DEV_HELPERS_ENABLED=false
VITE_DEV_QUICK_LOGIN_ENABLED=false
# VITE_DEV_LOGIN_ADMIN_EMAIL=admin@test.local
# VITE_DEV_LOGIN_ADMIN_PASSWORD=TestPassword123!
# VITE_DEV_LOGIN_EDITOR_EMAIL=editor@test.local
# VITE_DEV_LOGIN_EDITOR_PASSWORD=TestPassword123!
# VITE_DEV_LOGIN_VIEWER_EMAIL=viewer@test.local
# VITE_DEV_LOGIN_VIEWER_PASSWORD=TestPassword123!
# VITE_DEV_LOGIN_PARTICIPANT_EMAIL=participant@test.local
# VITE_DEV_LOGIN_PARTICIPANT_PASSWORD=TestPassword123!

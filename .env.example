# QDesigner Modern - Environment Configuration
# Copy this file to .env.development for local development

# ---------- Database ----------
# PostgreSQL connection string (matches docker-compose.yml)
DATABASE_URL=postgresql://qdesigner:qdesigner@localhost:5432/qdesigner

# ---------- Auth ----------
# JWT signing secret (must be at least 32 characters)
JWT_SECRET=change-me-to-a-secure-secret-at-least-32-characters
# Separate secret for refresh tokens
JWT_REFRESH_SECRET=change-me-to-another-secure-secret-at-least-32-chars
# Access token expiry in seconds (default: 15 minutes)
JWT_ACCESS_EXPIRY=900
# Refresh token expiry in seconds (default: 7 days)
JWT_REFRESH_EXPIRY=604800

# ---------- Storage (MinIO) ----------
# MinIO S3-compatible API endpoint
MINIO_ENDPOINT=http://localhost:9000
# MinIO root credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Bucket for media uploads
MINIO_BUCKET=qdesigner-media

# ---------- Redis ----------
# Redis connection URL for caching and sessions
REDIS_URL=redis://localhost:6379

# ---------- Email (MailPit in dev) ----------
# SMTP server host
SMTP_HOST=localhost
# SMTP server port
SMTP_PORT=1025
# Sender address for outgoing emails
SMTP_FROM=noreply@qdesigner.local

# ---------- Server ----------
# Host and port the Rust backend listens on
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# ---------- Frontend ----------
# Backend API URL (used by SvelteKit client)
VITE_API_URL=http://localhost:3000
# WebSocket URL for real-time features
VITE_WS_URL=ws://localhost:3000/api/ws
# Public URL of the frontend app
VITE_APP_URL=http://localhost:5173
